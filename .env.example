# VamsaSetu Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database Connection
# Format: postgresql://username:password@host:port/database
# Used for: User accounts, events, notifications, audit logs
POSTGRES_URL=postgresql://vamsasetu:vamsasetu123@localhost:5432/vamsasetu

# Neo4j Graph Database Connection
# Format: bolt://host:port
# Used for: Family tree members and relationships
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=vamsasetu123

# Redis Cache Connection
# Format: host:port
# Used for: Caching family tree data, session management, performance optimization
REDIS_ADDR=localhost:6379

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Secret Key
# IMPORTANT: Generate a strong random secret for production
# Example: openssl rand -base64 32
# Used for: Signing and verifying JWT tokens for user authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Token Expiry (optional, defaults to 15 minutes for access token)
# JWT_ACCESS_TOKEN_EXPIRY=15m
# JWT_REFRESH_TOKEN_EXPIRY=168h

# =============================================================================
# NOTIFICATION SERVICES
# =============================================================================

# SendGrid Email Service
# Get your API key from: https://app.sendgrid.com/settings/api_keys
# Used for: Sending email notifications for family events
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Twilio SMS & WhatsApp Service
# Get your credentials from: https://console.twilio.com/
# Used for: Sending SMS and WhatsApp notifications for family events
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here

# Twilio Phone Numbers
# Format: E.164 format (e.g., +1234567890)
# SMS Phone Number: Your Twilio phone number for SMS
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Number: Your Twilio WhatsApp-enabled number
# Note: Must be approved by Twilio for WhatsApp messaging
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# =============================================================================
# APPLICATION CONFIGURATION (Optional)
# =============================================================================

# Server Port (default: 8080)
# PORT=8080

# Environment Mode (development, staging, production)
# ENV=development

# CORS Allowed Origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Log Level (debug, info, warn, error)
# LOG_LEVEL=info

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Backend API URL (for frontend)
# REACT_APP_API_URL=http://localhost:8080

# WebSocket URL (for frontend real-time updates)
# REACT_APP_WS_URL=ws://localhost:8080

# =============================================================================
# NOTIFICATION SCHEDULER CONFIGURATION (Optional)
# =============================================================================

# Notification check interval (default: 1 hour)
# NOTIFICATION_CHECK_INTERVAL=1h

# Maximum concurrent notification workers (default: 10)
# NOTIFICATION_MAX_WORKERS=10

# Maximum notification retry attempts (default: 3)
# NOTIFICATION_MAX_RETRIES=3

# =============================================================================
# CACHE CONFIGURATION (Optional)
# =============================================================================

# Cache TTL values in minutes
# CACHE_MEMBER_TTL=10
# CACHE_FAMILY_TREE_TTL=5
# CACHE_RELATIONSHIP_TTL=10
# CACHE_SEARCH_TTL=2
# CACHE_EVENTS_TTL=5

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================

# Enable debug mode (default: false)
# DEBUG=false

# Enable SQL query logging (default: false)
# LOG_SQL_QUERIES=false

# Seed database with demo data on startup (default: false)
# SEED_DEMO_DATA=false

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. NEVER commit the actual .env file to version control
# 2. Keep your JWT_SECRET secure and rotate it periodically
# 3. Use strong passwords for database credentials in production
# 4. Obtain valid API keys from SendGrid and Twilio for notifications
# 5. For production, use environment-specific values and secrets management
# 6. Ensure all required variables are set before starting the application
# 
# =============================================================================
